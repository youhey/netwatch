{
  "listen_addr": "0.0.0.0:8080",
  "data_path": "/var/lib/netwatch/samples.jsonl",
  "ping_interval_seconds": 30,
  "ping_count": 10,
  "ping_timeout_seconds": 15,
  "targets": [
    {
      "name": "gateway",
      "type": "ping",
      "target": "192.168.1.1"
    },
    {
      "name": "cloudflare_dns",
      "type": "ping",
      "target": "1.1.1.1"
    },
    {
      "name": "google_dns",
      "type": "ping",
      "target": "8.8.8.8"
    }
  ]
}
